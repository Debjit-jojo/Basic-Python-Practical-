#include <stdio.h>
#include <ctype.h>
#include <string.h>

int main() {
    char str[200];
    int vowels = 0, consonants = 0, spaces = 0, lowercase = 0;

    // -------- Lab Assignment 1 --------
    printf("Enter a string: ");
    fgets(str, sizeof(str), stdin);

    for (int i = 0; str[i] != '\0'; i++) {
        char ch = str[i];

        // Count vowels
        if (ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u'||
            ch=='A'||ch=='E'||ch=='I'||ch=='O'||ch=='U') {
            vowels++;
        }
        // Count consonants
        else if (isalpha(ch)) {
            consonants++;
        }

        // Count spaces
        if (ch == ' ') {
            spaces++;
        }

        // Count lowercase letters
        if (islower(ch)) {
            lowercase++;
        }
    }

    printf("\n--- String Statistics ---\n");
    printf("Vowels: %d\n", vowels);
    printf("Consonants: %d\n", consonants);
    printf("Spaces: %d\n", spaces);
    printf("Lowercase Letters: %d\n", lowercase);

    // -------- Lab Assignment 2 --------
    printf("\nEnter a sentence to convert to uppercase: ");
    fgets(str, sizeof(str), stdin);

    for (int i = 0; str[i] != '\0'; i++) {
        str[i] = toupper(str[i]);
    }

    printf("Uppercase Output: %s\n", str);

    return 0;
}
